# Data provider: akshare (default) or tushare
STOCKROCK_DATA_PROVIDER=akshare

# Cache directory (relative to project root or absolute path)
STOCKROCK_CACHE_DIR=data/cache

# Watchlist persistence file
STOCKROCK_WATCHLIST_PATH=data/watchlist.json

# Overlap days when incrementally updating cached bars (default 5)
STOCKROCK_CACHE_INCREMENTAL_OVERLAP_DAYS=5

# Tushare Pro token (required when STOCKROCK_DATA_PROVIDER=tushare)
TUSHARE_TOKEN=

# Default lookback days for screening
STOCKROCK_LOOKBACK_DAYS=120

# Parallel screening threads (default min(16, CPU*2); lower if AKShare rate-limits)
# STOCKROCK_SCREEN_WORKERS=8

# API server
STOCKROCK_HOST=0.0.0.0
STOCKROCK_PORT=8000
